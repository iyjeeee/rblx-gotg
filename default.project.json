{
  "name": "GameOfTheGenerals",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": { "$path": "src/ReplicatedStorage/Shared" },
      "Remotes": {
        "$className": "Folder",
        "Match": {
          "$className": "Folder",
          "SubmitSetup": { "$className": "RemoteFunction" },
          "SubmitMove": { "$className": "RemoteFunction" },
          "StateUpdate": { "$className": "RemoteEvent" }
        },
        "Matchmaking": {
          "$className": "Folder",
          "FindMatch": { "$className": "RemoteFunction" },
          "CancelQueue": { "$className": "RemoteFunction" },
          "MatchFound": { "$className": "RemoteEvent" }
        }
      },
      "UI": { "$path": "src/ReplicatedStorage/UI" }
    },

    "ServerScriptService": {
      "Services": { "$path": "src/ServerScriptService/Services" }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Controllers": { "$path": "src/StarterPlayerScripts/Controllers" }
      }
    },

    "ServerStorage": {
      "$path": "src/ServerStorage"
    }
  }
}